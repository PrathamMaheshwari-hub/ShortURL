<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        body {
            font-family: Arial;
            background-color: #0b8bbe;
            margin: 0;
            padding: 20px;
        }
        
    </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home page</title>
</head>
<body>
    <h1>URL Shortener</h1>
     <div>
     <% if (locals.id) { %>
      <p>URL Generated: https://localhost:3000/url/<%= id %></p>
     <% } %>   
        <form method="POST" action="/url">
            <label>Enter Your Original Url</label>
            <input type="text" name="url" placeholder="https://example.com"/>
            <button type="submit">Shorten</button>

        </form>
     </div>
     <div>
        <% if (locals.urls) { %>
              <table>
                  <thead>
                          <th>S. No</th>
                          <th>Redirect URL</th>
                          <th>Short URL</th>
                          <th>Clicks</th>
                  </thead>
                  <tbody>
                      <% locals.urls.forEach((url, index) => { %>
                        <tr>
                          <td><%= index + 1 %></td>
                        <tb><%= url.shortId %></tb>
                          <td><%= url.redirectUrl %></td>
                          <td><%= url.visitHistory.length %></td>
                         </tr>
                      <% }) %>
                  </tbody>
              </table>
            
        <% } %>
         
     </div>
</body>
</html>